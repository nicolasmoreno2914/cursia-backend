# ──────────────────────────────────────────────
# Orbia Backend — Variables de entorno
# Copia este archivo como .env y ajusta los valores.
# NUNCA commitear el archivo .env con valores reales.
# ──────────────────────────────────────────────

# ── Aplicación ──────────────────────────────────
NODE_ENV=development
PORT=3000

# ── CORS ────────────────────────────────────────
# Lista de orígenes permitidos, separados por coma, sin espacios.
# Desarrollo: puedes incluir localhost
# Producción: SOLO dominios reales del frontend. NUNCA usar *.
CORS_ORIGIN=http://localhost:5173,https://orbia.pages.dev

# ── PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=orbia
DB_PASS=orbia_dev
DB_NAME=orbia
# En producción: DB_SSL=true
DB_SSL=false
# En producción: DB_LOGGING=false
DB_LOGGING=false

# ──────────────────────────────────────────────
# Supabase JWT Auth (Fase 6)
# ──────────────────────────────────────────────

# URL de tu proyecto Supabase.
# REQUERIDO para proyectos nuevos (ES256/JWKS — algoritmo asimétrico).
# Formato: https://TU_PROJECT_REF.supabase.co
# Supabase Dashboard → Settings → API → URL
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT Secret — SOLO para proyectos Supabase legacy que usan HS256 (simétrico).
# Si tu proyecto usa ES256 (la mayoría de proyectos nuevos), deja esto VACÍO
# y configura SUPABASE_URL en su lugar.
# Para verificar: curl https://TU_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
#   → si responde con "alg":"ES256" → usar SUPABASE_URL (dejar este campo vacío)
#   → si no hay JWKS → usar este campo con el secret del Dashboard
# NUNCA commitear el valor real. Copiar solo en .env local.
SUPABASE_JWT_SECRET=

# Service Role Key — para operaciones server-side en Supabase Storage
# Supabase Dashboard → Settings → API → service_role key
# Necesario para: signed download URLs de artifacts, borrado de archivos storage
# Si no se configura, el frontend genera las URLs con su propio SDK (fallback seguro)
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
# YouTube OAuth (Fase Y1)
# ──────────────────────────────────────────────

# ID y secret de la app en Google Cloud Console.
# Dashboard → APIs & Services → Credentials → OAuth 2.0 Client IDs
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# URI de redirección que Google llama al completar el OAuth.
# Debe coincidir EXACTAMENTE con lo configurado en Google Cloud Console.
# Desarrollo:  http://localhost:3000/api/v1/youtube/oauth/callback
# Producción:  https://api.tu-dominio.com/api/v1/youtube/oauth/callback
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/youtube/oauth/callback

# Secreto para cifrar refresh tokens con AES-256-GCM.
# REQUERIDO si YOUTUBE_CLIENT_ID está configurado. Mínimo 32 caracteres.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NUNCA commitear el valor real.
YOUTUBE_TOKEN_SECRET=

# Privacidad por defecto para videos subidos a YouTube.
# Valores: unlisted | private | public
# Recomendado: unlisted (usuario puede cambiar después en YouTube Studio)
YOUTUBE_DEFAULT_PRIVACY=unlisted

# URL del frontend — usada para redirigir al usuario tras el callback de Google.
# Desarrollo:  http://localhost:5173
# Producción:  https://cursia.nomaddi.com
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Video Worker — proceso separado que genera y sube videos
# ──────────────────────────────────────────────

# Habilitar el worker (false = sale inmediatamente sin procesar nada)
VIDEO_WORKER_ENABLED=false

# true = completar rápido sin generar nada real (para health-checks)
VIDEO_WORKER_DRY_RUN=false

# true = usar Videogen real (VIDEOGEN_API_URL + VIDEOGEN_API_KEY requeridos)
# false = mock de Videogen en memoria (no llama a ninguna API)
VIDEO_WORKER_ENABLE_REAL_VIDEOGEN=false
VIDEO_WORKER_MOCK_VIDEOGEN=true

# Escenario del mock de Videogen: success | partial_failure | all_failed | timeout
VIDEO_WORKER_MOCK_SCENARIO=success

# Cuántos jobs procesar en paralelo (recomendado: 1 para no saturar YouTube)
VIDEO_WORKER_CONCURRENCY=1

# Intervalo entre polls de la cola de jobs (ms)
VIDEO_WORKER_POLL_MS=3000

# Duración máxima del lease de un job (s) — el worker renueva cada heartbeat
VIDEO_WORKER_LEASE_SECONDS=60

# Intervalo de heartbeat para renovar el lease (ms)
VIDEO_WORKER_HEARTBEAT_MS=15000

# Intervalo entre polls de Videogen (ms) — ignorado en mock
VIDEO_WORKER_VIDEOGEN_POLL_MS=15000

# Tiempo máximo esperando a Videogen (min) — pasado este tiempo el job falla
VIDEO_WORKER_MAX_POLL_MINUTES=60

# ── YouTube upload (dentro del video worker) ──────────────────────

# true = habilitar la fase de subida a YouTube tras generar los videos
YOUTUBE_UPLOAD_ENABLED=false

# true = simular uploads en memoria (no llama a YouTube API)
# false = upload real usando las credenciales del usuario (YOUTUBE_CLIENT_ID requerido)
YOUTUBE_UPLOAD_MOCK=true

# Escenario del mock de YouTube: success | partial_failure | all_failed | quota_exceeded | auth_required
YOUTUBE_UPLOAD_MOCK_SCENARIO=success

# Retraso artificial del mock de YouTube (ms)
YOUTUBE_UPLOAD_MOCK_DELAY_MS=500

# ──────────────────────────────────────────────
# Videogen API (Fase Y3)
# ──────────────────────────────────────────────

# Secret compartido para verificar firmas HMAC en callbacks de Videogen.
VIDEOGEN_WEBHOOK_SECRET=

# URL base de la API de Videogen.
VIDEOGEN_API_URL=

# API key de institución en Videogen (formato: veia_live_...)
VIDEOGEN_API_KEY=

# ──────────────────────────────────────────────
# Admin Dashboard (Fase D0)
# ──────────────────────────────────────────────

# Emails con acceso al panel de administración interno.
# Lista separada por comas. Case-insensitive.
# GET /api/v1/admin/dashboard/summary requiere estar en esta lista.
# NUNCA commitear emails reales. Copiar solo en .env local / secretos de producción.
# Ejemplo: SUPER_ADMIN_EMAILS=admin@cursia.com,nicolas@cursia.com
SUPER_ADMIN_EMAILS=

# ──────────────────────────────────────────────
# Compatibilidad legacy
# ──────────────────────────────────────────────

# ALLOW_UNOWNED_COURSES
# true  → incluye cursos sin owner_id en los listados (para desarrollo con datos legacy)
# false → PRODUCCIÓN: solo muestra cursos del usuario autenticado
#
# ⚠️  DEBE SER FALSE EN PRODUCCIÓN. true solo para desarrollo local con datos pre-Fase 6.
ALLOW_UNOWNED_COURSES=false

# ──────────────────────────────────────────────
# OpenAI TTS (Fase Audio — bienvenida y audiolibro)
# ──────────────────────────────────────────────

# API key de OpenAI para síntesis de voz.
# NUNCA exponer en frontend. Solo backend usa esta key.
# Dashboard: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo TTS (default: gpt-4o-mini-tts)
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Voz por defecto (default: marin)
# Voces disponibles: alloy, ash, ballad, coral, echo, fable, marin, nova, onyx, sage, shimmer, verse
OPENAI_TTS_VOICE=marin
