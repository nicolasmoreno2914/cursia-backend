# ──────────────────────────────────────────────
# Orbia Backend — variables de entorno
# Copia este archivo como .env y ajusta los valores
# ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# CORS — lista de orígenes separados por coma
# En desarrollo puedes usar * para permitir todo
CORS_ORIGIN=http://localhost:5173,https://orbia.pages.dev

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=orbia
DB_SSL=false
DB_LOGGING=false

# ──────────────────────────────────────────────
# Supabase JWT Auth (Fase 6)
# ──────────────────────────────────────────────

# JWT Secret de tu proyecto Supabase.
# URL del proyecto Supabase (para verificación ES256 via JWKS — proyectos nuevos)
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT Secret (solo para proyectos legacy HS256 — dejar vacío si el proyecto usa ES256)
# Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# NUNCA commitear el valor real. Copiar en .env local.
SUPABASE_JWT_SECRET=

# Compatibilidad con cursos creados antes de la Fase 6 (sin owner_id).
# true  → en desarrollo, permite ver cursos sin owner_id (legacy)
# false → producción estricta, solo cursos del usuario autenticado
ALLOW_UNOWNED_COURSES=false
