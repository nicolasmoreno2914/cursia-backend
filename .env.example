# ──────────────────────────────────────────────
# Orbia Backend — variables de entorno
# Copia este archivo como .env y ajusta los valores
# ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# CORS — lista de orígenes separados por coma
# En desarrollo puedes usar * para permitir todo
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=orbia
DB_SSL=false
DB_LOGGING=false
