# ══════════════════════════════════════════════════════════════════════════════
# .env.production.template — Variables para VPS Contabo
# ══════════════════════════════════════════════════════════════════════════════
# 1. Copiar este archivo como .env en /var/www/cursia-backend/.env
# 2. Rellenar TODOS los valores marcados con <VALOR>
# 3. chmod 600 .env
# 4. NUNCA commitear el .env con valores reales
# ══════════════════════════════════════════════════════════════════════════════

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Base de datos (Supabase PostgreSQL) ───────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection info
# Usar: Direct connection o Session Pooler (puerto 5432)
# NO usar Transaction Pooler (puerto 6543) — incompatible con TypeORM
DB_HOST=db.<PROJECT_REF>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASS=<TU_PASSWORD_SUPABASE>
DB_NAME=postgres
DB_SSL=true
DB_LOGGING=false

# ── Supabase Auth/JWT ─────────────────────────────────────────────────────────
# REQUERIDO: URL del proyecto para JWKS/ES256
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Dejar vacío si el proyecto usa ES256 (caso actual — proyectos nuevos)
SUPABASE_JWT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Solo el frontend de producción. Sin wildcard *.
CORS_ORIGIN=https://cursia.nomaddi.com

# ── URLs públicas ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://cursia.nomaddi.com
BACKEND_PUBLIC_URL=https://api.cursia.nomaddi.com

# ── YouTube OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
YOUTUBE_CLIENT_ID=<TU_CLIENT_ID>.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=<TU_CLIENT_SECRET>
YOUTUBE_REDIRECT_URI=https://api.cursia.nomaddi.com/api/v1/youtube/oauth/callback
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
YOUTUBE_TOKEN_SECRET=<CADENA_ALEATORIA_64_CHARS>
YOUTUBE_DEFAULT_PRIVACY=unlisted

# ── Video Worker ─────────────────────────────────────────────────────────────
# El video-worker es un proceso separado. Arrancar con: npm run worker:video
VIDEO_WORKER_ENABLED=true
VIDEO_WORKER_DRY_RUN=false
VIDEO_WORKER_ENABLE_REAL_VIDEOGEN=true
VIDEO_WORKER_MOCK_VIDEOGEN=false
VIDEO_WORKER_MOCK_SCENARIO=success
VIDEO_WORKER_CONCURRENCY=1
VIDEO_WORKER_POLL_MS=3000
VIDEO_WORKER_LEASE_SECONDS=60
VIDEO_WORKER_HEARTBEAT_MS=15000
VIDEO_WORKER_VIDEOGEN_POLL_MS=15000
VIDEO_WORKER_MAX_POLL_MINUTES=60
# YouTube upload: true = habilitar subida real a YouTube tras generar videos
YOUTUBE_UPLOAD_ENABLED=true
YOUTUBE_UPLOAD_MOCK=false
YOUTUBE_UPLOAD_MOCK_SCENARIO=success
YOUTUBE_UPLOAD_MOCK_DELAY_MS=500

# ── Videogen (videosb.nomaddi.com — External API) ────────────────────────────
# URL base del servicio Videogen propio
VIDEOGEN_API_URL=https://videosb.nomaddi.com
# API key de institución "Cursia" en Videogen (formato: veia_live_...)
# Generarla en: Videogen → Admin → API Keys → Nueva key para institución Cursia
VIDEOGEN_API_KEY=<veia_live_XXXXXXXXXXXXXXXX>

# ── Anthropic (generación de contenido en servidor) ───────────────────────────
# Requerido para que el content-worker use Claude en lugar de templates
# Si no se configura, el worker genera contenido desde templates estáticos
ANTHROPIC_API_KEY=<sk-ant-XXXXXXXXXXXXXXXX>
# Modelo a usar (opcional, default: claude-sonnet-4-5)
CONTENT_MODEL=claude-sonnet-4-5
# HMAC secret para la API Cursia-specific (/api/v1/video-batches) — reservado para uso futuro
VIDEOGEN_SHARED_SECRET=
VIDEOGEN_WEBHOOK_SECRET=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=nicolas@nomaddi.com

# ── Seguridad ─────────────────────────────────────────────────────────────────
# CRÍTICO: siempre false en producción
ALLOW_UNOWNED_COURSES=false
